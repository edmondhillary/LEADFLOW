# ==================== TELEGRAM ====================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=123456789

# ==================== BREVO (EMAIL) ====================
BREVO_API_KEY=xkeysib-xxxxx
BREVO_SENDER_EMAIL=hola@tudominio.com
BREVO_SENDER_NAME=LeadFlow

# ==================== SCRAPING ====================
OUTSCRAPER_API_KEY=xxxxx
APIFY_KEY=xxxxx
APIFY_GOOGLE_MAPS_ACTOR_ID=compass/crawler-google-places
SERPER_API_KEY=xxxxx

# ==================== SCRAPING COST CONTROL ====================
# ON por defecto: reduce rondas y volumen para bajar coste Apify
SCRAPE_ECO_MODE=1
# Descarta negocios fuera de la ciudad objetivo
SCRAPE_STRICT_CITY=1
# Límites de scraping por ejecución
SCRAPE_MAX_ROUNDS=2
SCRAPE_BATCH_MULTIPLIER=2
SCRAPE_MAX_BATCH_PER_ROUND=80
# Evita re-scrape si ya hay pool reciente en Mongo (horas)
SCRAPE_QUERY_CACHE_HOURS=24
# Límite duro de resultados solicitados por query al actor
SCRAPE_MAX_RESULTS_PER_QUERY=80

# ==================== OVERRIDE V2 ROLLOUT ====================
LF_OVERRIDE_V2_ENABLED=1
LF_OVERRIDE_V2_CONTACTO=1
LF_OVERRIDE_V2_NOSOTROS=1
LF_OVERRIDE_V2_BLOG=1
LF_OVERRIDE_V2_BLOG_POST=1

# ==================== TRACKING / VISIT QUALITY ====================
# Ignora la primera visita humana al link (warmup/manual check)
TRACK_IGNORE_FIRST_VISIT=1
# Ventana de dedupe por visitante (minutos)
TRACK_DEDUPE_MINUTES=45

# ==================== GOOGLE MAPS (opcional) ====================
NEXT_PUBLIC_GOOGLE_MAPS_KEY=xxxxx
